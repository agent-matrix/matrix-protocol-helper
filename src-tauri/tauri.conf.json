{
  "$schema": "https://schema.tauri.app/config/v2",
  "identifier": "io.matrixhub.client",
  "productName": "MatrixHub Client",
  "version": "0.2.0",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "MatrixHub Client",
        "url": "/",
        "width": 1140,
        "height": 760,
        "minWidth": 880,
        "minHeight": 560,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "visible": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "dmg", "app", "deb", "rpm"],
    "publisher": "MatrixHub",
    "homepage": "https://www.matrixhub.io/",
    "copyright": "Copyright © 2026 MatrixHub",
    "category": "DeveloperTool",
    "shortDescription": "MatrixHub desktop client and local runner.",
    "longDescription": "MatrixHub Client is the official cross-platform desktop companion for MatrixHub. It manages the local Matrix CLI runtime, handles matrix:// one-click installs with an in-app review, and provides a terminal, logs, and diagnostics for your local AI environment.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "allowDowngrades": false,
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com",
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "both",
        "languages": ["English"],
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "startMenuFolder": "MatrixHub"
      },
      "wix": {
        "upgradeCode": "819AD1D8-034E-47EB-9D09-AE83FEA024CC",
        "language": "en-US"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["matrix"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJGMjk2MkM3MkIxNzY1MkUKUldRdVpSY3J4MklwTHhoM2ZDZUdnamhsSGk2eVJ2dmhxRUxBK09COUUrVzBvWXNocE9pdUo5dFEK",
      "endpoints": [
        "https://www.matrixhub.io/releases/{{target}}/{{arch}}/{{current_version}}"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
