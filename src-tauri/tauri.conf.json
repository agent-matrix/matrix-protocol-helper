{
  "$schema": "https://schema.tauri.app/config/v2",
  "identifier": "io.matrixhub.clihelper",
  "productName": "MatrixHub Client",
  "version": "0.2.0",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "MatrixHub Client",
        "url": "/",
        "width": 1140,
        "height": 760,
        "minWidth": 880,
        "minHeight": 560,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "visible": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "dmg",
      "app",
      "deb",
      "rpm"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "matrix"
        ]
      }
    }
  }
}
